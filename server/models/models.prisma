datasource db {
  provider = "sqlite"
  url = "file:./dev.db"
}

model User {
  id   Int @id
  username String @unique
  password String
  email String? @unique
  weixinKfUsers WeixinKfUser[]
  computers Computer[]
}

model WeixinKf {
  id String @id
  messageCursor String
  printTasks PrintTask[]
}

model WeixinKfUser {
  externalUserId String @id
  user User @relation(fields: [userId], references: [id])
  userId Int
}

model Computer {
  id String @id
  name String
  user User @relation(fields: [userId], references: [id])
  userId Int
  printers Printer[]
}

model Printer {
  id Int @id
  name String
  computer Computer @relation(fields: [computerId], references: [id])
  computerId String
  printTasks PrintTask[]
  disabled Boolean
}

model PrintTask {
  id Int @id
  state String
  weixinKf WeixinKf @relation(fields: [weixinKfId], references: [id])
  weixinKfId String
  externalUserId String
  printFiles PrintFile[]
  user User @relation(fields: [userId], references: [id])
  userId Int
  printer Printer @relation(fields: [printerId], references: [id])
  printerId Int
}

model PrintFile {
  id Int @id
  state String
  printTask PrintTask @relation(fields: [printTaskId], references: [id])
  printTaskId Int
  fileId String
  filename String
  duplex Boolean
  tumble Boolean
}
