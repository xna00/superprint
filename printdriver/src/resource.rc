#pragma code_page(65001)
#include <windows.h>

#define IDC_LOGIN_DLG 1000
#define IDC_USERNAME 100
#define IDC_PASSWORD 101
#define IDOK 1
#define IDCANCEL 2

IDC_LOGIN_DLG DIALOGEX 0, 0, 300, 150
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "登录"
FONT 9, "Microsoft YaHei UI"
BEGIN
    LTEXT "用户名:", -1, 20, 30, 60, 10
    EDITTEXT IDC_USERNAME, 80, 28, 180, 14, ES_AUTOHSCROLL
    LTEXT "密码:", -1, 20, 60, 60, 10
    EDITTEXT IDC_PASSWORD, 80, 58, 180, 14, ES_AUTOHSCROLL | ES_PASSWORD
    DEFPUSHBUTTON "登录", IDOK, 100, 100, 50, 14
    PUSHBUTTON "取消", IDCANCEL, 160, 100, 50, 14
END
