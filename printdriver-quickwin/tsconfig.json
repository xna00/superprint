{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "rootDir": "src",
    "outDir": "./dist-tsgo",
    "lib": ["ESNext"],
    "types": ["./node_modules/quickwin/quickwin.d.ts"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "./node_modules/quickwin/lib/react-qw/jsx.d.ts"],
  "exclude": []
}
